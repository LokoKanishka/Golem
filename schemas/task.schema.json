{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://golem.local/schemas/task.schema.json",
  "title": "Golem Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "objective",
    "status",
    "owner",
    "source_channel",
    "created_at",
    "updated_at",
    "acceptance_criteria",
    "evidence",
    "artifacts",
    "closure_note",
    "history"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^task-[0-9]{8}T[0-9]{6}Z-[a-z0-9]{6,16}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["todo", "running", "blocked", "done", "failed", "canceled"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "source_channel": {
      "type": "string",
      "enum": ["panel", "whatsapp", "operator", "script", "worker", "scheduled_process"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceItem"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "closure_note": {
      "type": "string"
    },
    "history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/historyItem"
      }
    }
  },
  "$defs": {
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "note"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "result": {
          "type": "string"
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "historyItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["at", "actor", "action", "note"],
      "properties": {
        "at": {
          "type": "string",
          "format": "date-time"
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
